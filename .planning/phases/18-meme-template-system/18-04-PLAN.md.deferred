Create `scripts/meme-overlay.ts`:

```typescript
#!/usr/bin/env bun
/**
 * Add punchline to memes - checks for existing text first
 * 
 * Usage:
 *   bun run scripts/meme-overlay.ts --template "success-kid" --punchline "You chose the safe option"
 *   bun run scripts/meme-overlay.ts --incident "AI model" --outcome "It hallucinated" --output "public/images/incidents/ai-hallucinate.webp"
 * 
 * IMPORTANT: Will check if template has pre-existing text FIRST
 * - If YES: uses template as-is (no overlay)
 * - If NO: adds punchline overlay
 */

import * as fs from "node:fs";
import * as path from "node:path";
import { generateMemeWithPunchline, templateHasText } from "../lib/meme-overlay";
import templates from "../data/templates/meme-templates.json";

// Parse args
const args = process.argv.slice(2);
let templateId = "";
let punchline = "";
let incident = "";
let outcome = "";
let outputPath = "";

for (let i = 0; i < args.length; i++) {
  if (args[i] === "--template" && args[i + 1]) templateId = args[i + 1];
  if (args[i] === "--punchline" && args[i + 1]) punchline = args[i + 1];
  if (args[i] === "--incident" && args[i + 1]) incident = args[i + 1];
  if (args[i] === "--outcome" && args[i + 1]) outcome = args[i + 1];
  if (args[i] === "--output" && args[i + 1]) outputPath = args[i + 1];
}

// Truncate outcome to punchline (8-10 words)
function makePunchline(text: string): string {
  const words = text.split(" ").slice(0, 10).join(" ");
  return words + (text.split(" ").length > 10 ? "..." : "");
}

async function main() {
  if (!templateId && !incident) {
    console.log(`
Add punchline to memes - checks for existing text FIRST

Usage:
  bun run scripts/meme-overlay.ts --template "template-id" --punchline "Your text here" --output "path/to/save.webp"
  bun run scripts/meme-overlay.ts --incident "What happened" --outcome "What happened next" --output "path/to/save.webp"

IMPORTANT: 
  - If template already has text (like "I Declare Bankruptcy"), uses as-is
  - Only adds overlay if template doesn't have pre-existing text

Examples:
  bun run scripts/meme-overlay.ts --template "success-kid" --punchline "You chose the safe option" --output "test.webp"
`);
    return;
  }
  
  // Find template
  let templateUrl = "";
  let foundTemplateId = templateId;
  
  if (incident && outcome) {
    // Use incident pattern to find template (simplified - would need mapping)
    punchline = makePunchline(outcome);
    console.log(`Generated punchline: "${punchline}"`);
  }
  
  if (templateId) {
    // Search for template in all categories
    const allTemplates = [
      ...Object.values(templates.deaths || {}),
      ...Object.values(templates.archetypes || {}),
      ...Object.values(templates.gifs || {})
    ].flat();
    
    const found = allTemplates.find((t: any) => t.id === templateId);
    if (found) {
      templateUrl = found.url;
    }
  }
  
  if (!templateUrl) {
    console.log(`❌ Template not found: ${templateId}`);
    return;
  }
  
  // Check if template has existing text FIRST
  console.log(`\nChecking template: ${templateId}`);
  
  // Find template info for check
  const allTemplates = [
    ...Object.values(templates.deaths || {}),
    ...Object.values(templates.archetypes || {}),
  ].flat();
  
  const templateInfo = allTemplates.find((t: any) => t.id === templateId);
  const hasExistingText = templateHasText(templateInfo);
  
  if (hasExistingText) {
    console.log(`⚠ Template "${templateId}" has pre-existing text - using as-is, NO overlay added`);
    console.log(`✓ Saved to: ${outputPath || "memory"}`);
  } else {
    console.log(`✓ Template has no existing text - adding punchline: "${punchline}"`);
    
    const result = await generateMemeWithPunchline(
      templateId,
      templateUrl,
      punchline,
      outputPath || undefined
    );
    
    if (result.buffer) {
      console.log(`✓ Saved to: ${outputPath || "memory"}`);
      console.log(`✓ Buffer size: ${result.buffer.length} bytes`);
    } else {
      console.log(`❌ Failed to generate meme`);
    }
  }
}

main();
```
