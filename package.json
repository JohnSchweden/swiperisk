{
	"name": "k-maru-the-hyperscale-chronicles",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"check": "biome check .",
		"fix": "biome check --write .",
		"format:file": "biome format --write",
		"fix:file": "biome check --write",
		"lint-staged:run": "lint-staged --allow-empty",
		"test": "playwright test",
		"test:smoke": "playwright test --grep @smoke",
		"test:visual": "playwright test --grep @visual",
		"test:slow": "playwright test --grep @slow",
		"test:area:gameplay": "playwright test --grep @area:gameplay",
		"test:area:input": "playwright test --grep @area:input",
		"test:area:layout": "playwright test --grep @area:layout",
		"test:area:boss": "playwright test --grep @area:boss",
		"test:area:audio": "playwright test --grep @area:audio",
		"test:changed": "bun run scripts/test-changed.ts",
		"test:unit": "vitest run unit/",
		"test:unit:watch": "vitest unit/",
		"test:data": "vitest run tests/data --reporter=verbose",
		"vitest:run": "vitest run",
		"test:file": "playwright test",
		"test:benchmark": "playwright test --config=playwright.benchmark.config.ts --reporter=json --reporter=list --timeout=60000",
		"playwright:install": "playwright install",
		"playwright:show-report": "playwright show-report",
		"playwright:show-trace": "playwright show-trace",
		"playwright:codegen": "playwright codegen",
		"compress:file": "bun scripts/compress-audio.ts file",
		"compress:dir": "bun scripts/compress-audio.ts directory",
		"compress:voices": "bun scripts/compress-audio.ts directory public/audio/voices",
		"compress:existing": "bun scripts/compress-existing-audio.ts",
		"compress:verify": "bun scripts/verify-compressed-audio.ts",
		"export:card-audit": "bun scripts/export-card-content-audit.ts",
		"convert:music:opus": "bun scripts/convert-music-to-opus.ts directory public/audio/music",
		"build:with-audio": "bun compress:existing && bun run build",
		"benchmark": "bun run scripts/benchmark-tests.ts",
		"benchmark:compare": "bun run scripts/benchmark-tests.ts -- --compare latest",
		"test:slow-files": "bun run scripts/find-slow-test-files.ts",
		"test:live-api": "bun run scripts/test-live-api.ts",
		"lint:file": "biome lint",
		"hooks:cursor-format": "bun ./.cursor/hooks/format.ts",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json}": "biome check --write"
	},
	"engines": {
		"node": "24.x"
	},
	"dependencies": {
		"@google/genai": "^1.40.0",
		"@google/generative-ai": "^0.24.1",
		"@mcp-b/global": "^2.2.0",
		"@mcp-b/react-webmcp": "^2.2.0",
		"@vercel/analytics": "^2.0.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sharp": "^0.34.5",
		"zod": "^3.25",
		"zod-to-json-schema": "^3.25.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4.2.2",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/fluent-ffmpeg": "^2.1.28",
		"@types/node": "^22.14.0",
		"@vercel/node": "^5.6.9",
		"@vitejs/plugin-basic-ssl": "^2.1.4",
		"@vitejs/plugin-react": "^5.0.0",
		"autoprefixer": "^10.4.27",
		"dotenv": "^17.3.1",
		"exceljs": "^4.4.0",
		"ffmpeg-static": "^5.3.0",
		"fluent-ffmpeg": "^2.1.3",
		"happy-dom": "^20.8.3",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.3.2",
		"playwright": "^1.58.2",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "~5.8.2",
		"vite": "^6.2.0",
		"vitest": "^4.0.18"
	}
}
