Create `lib/meme-overlay.ts`:

```typescript
import TextOnGif from "text-on-gif";
import * as fs from "node:fs";
import * as path from "node:path";
import { downloadMeme, MemeTemplate } from "./meme-downloader";

/**
 * Check if template has pre-existing text
 * Templates with has_text: true should NOT have overlay added
 */
export function templateHasText(template: MemeTemplate | undefined): boolean {
  // If template is undefined, no text
  if (!template) return false;
  
  // Check if marked as having text (templates like "I Declare Bankruptcy")
  // These are pre-captioned memes and should NOT have overlay added
  const textTemplates = [
    "waiting-skeleton",
    "zuckerberg-congress",
    "kirk-jailbreak-llm",
    "success-kid",
    "grus-plan",
    "disaster-girl",
    "change-my-mind",
    "theyre-same-picture",
    "this-is-fine",
    "never-think-out-of-box"
  ];
  
  return textTemplates.includes(template.id);
}

/**
 * Add punchline overlay to a meme
 * ONLY use this if template does NOT have pre-existing text
 */
export async function addPunchlineOverlay(
  templateId: string,
  templateUrl: string,
  punchline: string,
  outputPath?: string
): Promise<Buffer | null> {
  // First check: don't add overlay to templates that already have text
  const memeHasText = templateHasText({ id: templateId, name: "", url: templateUrl });
  if (memeHasText) {
    console.log(`⚠ Template ${templateId} already has text - skipping overlay`);
    return null;
  }
  
  try {
    // Download base template
    const localPath = await downloadMeme(templateId, templateUrl);
    const imageBuffer = fs.readFileSync(localPath);
    
    // Add text overlay
    const gif = new TextOnGif({
      file_path: imageBuffer,
      font_size: "24px",
      font_color: "white",
      stroke_color: "black",
      stroke_width: 2,
    });
    
    const result = await gif.textOnGif({
      text: punchline,
      alignment_x: "middle",
      alignment_y: "bottom",
      get_as_buffer: true,
    });
    
    // Save if output path provided
    if (outputPath && result) {
      fs.mkdirSync(path.dirname(outputPath), { recursive: true });
      fs.writeFileSync(outputPath, result);
    }
    
    return result;
  } catch (error) {
    console.error(`Error adding overlay:`, error);
    return null;
  }
}

/**
 * Generate meme with punchline - checks for existing text first
 * 
 * @returns { hasExistingText: true } if template already has text (no overlay added)
 * @returns { hasExistingText: false, buffer } if overlay was added
 */
export async function generateMemeWithPunchline(
  templateId: string,
  templateUrl: string,
  punchline: string,
  outputPath?: string
): Promise<{ hasExistingText: boolean; buffer?: Buffer; outputPath?: string }> {
  // FIRST: Check if template has pre-existing text
  const template = { id: templateId, name: "", url: templateUrl };
  if (templateHasText(template)) {
    // Use as-is - download and save without overlay
    const localPath = await downloadMeme(templateId, templateUrl);
    
    if (outputPath) {
      fs.mkdirSync(path.dirname(outputPath), { recursive: true });
      fs.copyFileSync(localPath, outputPath);
      return { hasExistingText: true, outputPath };
    }
    
    const buffer = fs.readFileSync(localPath);
    return { hasExistingText: true, buffer };
  }
  
  // SECOND: No existing text - add punchline overlay
  const buffer = await addPunchlineOverlay(templateId, templateUrl, punchline, outputPath);
  
  if (!buffer) {
    // Fallback to using template as-is
    const localPath = await downloadMeme(templateId, templateUrl);
    const fallbackBuffer = fs.readFileSync(localPath);
    
    if (outputPath) {
      fs.mkdirSync(path.dirname(outputPath), { recursive: true });
      fs.writeFileSync(outputPath, fallbackBuffer);
    }
    
    return { hasExistingText: false, buffer: fallbackBuffer, outputPath };
  }
  
  return { hasExistingText: false, buffer, outputPath };
}
```
